# TenderFlow customer-facing environment template.
#
# Copy to `.env` next to docker-compose.dist.yml, fill in the four required
# values, then run:
#   docker compose -f docker-compose.dist.yml up -d
#
# After containers start, browse to https://YOUR-DOMAIN/setup to run the
# first-run wizard.

# ─── REQUIRED ────────────────────────────────────────────────────────────

# Public hostname for your install. Used by Caddy to obtain Let's Encrypt
# certificates automatically. For local testing without HTTPS, set DOMAIN
# to ":80" and keep HTTP_PORT=8080.
DOMAIN=tenderflow.example.com
DOMAIN_URL=https://tenderflow.example.com
ACME_EMAIL=admin@example.com

# Postgres password. Use a long random string in production.
# Generate one: openssl rand -base64 32
POSTGRES_PASSWORD=

# JWT signing secret. MUST be 32+ random characters.
# Generate one: openssl rand -base64 48
JWT_SECRET=


# ─── OPTIONAL ────────────────────────────────────────────────────────────

# Image registry owner (GitHub org publishing the images). Override only
# if you've forked and published your own images under a different org.
IMAGE_OWNER=nutridelightudr

# Image tag to pull. During beta we ship the rolling `latest` so new
# customer installs always pick up the most recent fixes without us
# updating the installer files. Pin to a specific semver (e.g. 1.0.1)
# once beta closes and you want install reproducibility for support.
APP_VERSION=latest

# Postgres user/database — change only if migrating from an existing
# install with different names.
POSTGRES_USER=tenderflow_user
POSTGRES_DB=tenderflow

# Caddy host ports.
#
# Defaults are 8080/8443 so the stack ALWAYS starts cleanly without clashing
# with anything else on the host. For a real production domain with automatic
# Let's Encrypt certificates, change these to 80/443 — the ACME HTTP-01
# challenge requires the standard ports.
#
# For local dev, leave the defaults and browse to http://localhost:8080 .
HTTP_PORT=8080
HTTPS_PORT=8443

# Take a pg_dump before each migrate. Recommended for production.
MIGRATE_BACKUP=false

# Sentry error monitoring (optional).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
